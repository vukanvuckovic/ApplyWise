# Appwrite project endpoint (e.g. https://cloud.appwrite.io/v1)
NEXT_PUBLIC_ENDPOINT=

# Your Appwrite project ID
NEXT_PUBLIC_PROJECT_ID=

# Database ID
NEXT_PUBLIC_DATABASE_ID=

# Storage bucket ID (for file uploads)
NEXT_PUBLIC_BUCKET_ID=

# Collection IDs
NEXT_PUBLIC_NOTES_COLLECTION_ID=
NEXT_PUBLIC_FILES_COLLECTION_ID=
NEXT_PUBLIC_USERS_COLLECTION_ID=
NEXT_PUBLIC_APPLICATIONS_COLLECTION_ID=

# Appwrite server-side API key (never expose this in the client)
NEXT_APPWRITE_SECRET=
